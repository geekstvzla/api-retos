extends ../../layout

block head_styles
    style
        include ../../../assets/css/emails/congratsForEnroll.css

block content
    h2 ¡Felicidades, #{userName}! 🥳
    
    p.message
        | Te has registrado en el evento #[strong #{eventTitle}] con el número de inscripción #[strong #{enrollNumber}] en la modalidad #[strong #{eventModality}]. Este número es tu identificación única para el evento, #[strong NO LO PIERDAS].

    p.message(style="margin-top: 15px;")
        | Elegiste el kit: #[strong #{eventKit}]

    if kitItems && kitItems.length > 0
        table.table(cellpadding="0" cellspacing="0" width="100%" style="margin-top: 25px; margin-bottom: 25px;")
            thead
                tr
                    each item in kitItems
                        th= item.attribute
            tbody
                tr
                    each item in kitItems
                        td= item.attribute_value

    if eventWhatsappEnrolledGroup
        p.message(style="margin-top: 25px; margin-bottom: 15px;")
            | Para mantenerte informado día a día, te invitamos a unirte al grupo de WhatsApp:
        a.btn-whatsapp-group(target="_blank" href=eventWhatsappEnrolledGroup) Únete a nuestro grupo de WhatsApp

    p.message(style="margin-top: 30px; font-weight: bold; border-top: 1px solid #eee; padding-top: 20px;")
        | ¿Necesitas comunicarte con alguien relacionado al evento?
    p.message(style="margin-top: 5px; color: #6b7280; font-size: 14px;")
        | A continuación te mostramos los datos de contacto:

    table.table(cellpadding="0" cellspacing="0" width="100%" style="margin-top: 15px;")
        thead
            tr
                th Nombre
                th N° de teléfono
                th N° WhatsApp
        tbody
            if contacts && contacts.length > 0
                each contact in contacts
                    tr
                        td= contact.full_name
                        td= contact.phone_number
                        td= contact.whatsapp_number