extends ../../layout

block head_styles
    style
        include ../../../assets/css/emails/userAccessCode.css

block content
    h2 🔓 Here's your access code!

    p.message
        | The Access Code is a random, one-time code that is generated each time you enter the system, giving you much more security than having a password.

    table.code-box(cellpadding="0" cellspacing="0")
        tr
            td
                = accessCode